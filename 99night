-- ===== HỆ THỐNG ESP KHÔNG DÙNG DRAWING =====
local espGUI = Instance.new("ScreenGui")
espGUI.Name = "ESPGUI"
espGUI.Parent = LocalPlayer:WaitForChild("PlayerGui")
espGUI.ResetOnSpawn = false

local espCache = {}  -- lưu các khung hình

local function ClearESP()
    for _, v in pairs(espCache) do
        if v then v:Destroy() end
    end
    espCache = {}
end

local function UpdateESP()
    if not Features.ESP then
        ClearESP()
        return
    end
    -- Xoá các phần tử cũ
    ClearESP()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local isPlayer = obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") and obj:FindFirstChild("Humanoid")
        local isItem = obj:IsA("Tool") or (obj:IsA("Part") and obj.Name:lower():find("item"))
        local isMonster = obj:IsA("Model") and obj.Name:lower():find("monster") or obj:FindFirstChild("Monster")
        local isChest = obj.Name:lower():find("chest")
        local isTree = obj.Name:lower():find("tree")
        local isResource = obj.Name:lower():find("resource") or obj.Name:lower():find("wood") or obj.Name:lower():find("stone")

        local shouldDraw = false
        local color = Color3.new(1,1,1)
        if isPlayer and obj ~= LocalPlayer.Character then
            shouldDraw = true
            color = Color3.new(1,0,0)
        elseif isMonster then
            shouldDraw = true
            color = Color3.new(1,0.5,0)
        elseif isItem then
            shouldDraw = true
            color = Color3.new(0,1,0)
        elseif isChest then
            shouldDraw = true
            color = Color3.new(1,1,0)
        elseif isTree then
            shouldDraw = true
            color = Color3.new(0,1,0)
        elseif isResource then
            shouldDraw = true
            color = Color3.new(0,0,1)
        end

        if shouldDraw then
            local rootPart = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Handle") or obj
            if rootPart and rootPart:IsA("BasePart") then
                local pos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
                if onScreen and pos.Z > 0 then
                    local box = Instance.new("Frame")
                    box.Size = UDim2.new(0, 40, 0, 40)
                    box.Position = UDim2.new(0, pos.X - 20, 0, pos.Y - 20)
                    box.BackgroundTransparency = 1
                    box.BorderSizePixel = 2
                    box.BorderColor3 = color
                    box.Parent = espGUI
                    table.insert(espCache, box)
                end
            end
        end
    end
end

-- ===== HỆ THỐNG TELEPORT KHÔNG CẦN TÊN =====
local function TeleportToNearestInteractable()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local closest, dist = nil, math.huge
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local cd = obj:FindFirstChildOfClass("ClickDetector")
        local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
        if (cd or prompt) and obj:IsA("BasePart") then
            local d = (obj.Position - root.Position).Magnitude
            if d < dist then
                dist = d
                closest = obj
            end
        end
    end
    if closest then
        root.CFrame = CFrame.new(closest.Position + Vector3.new(0,3,0))
        game:GetService("StarterGui"):SetCore("SendNotification", {Text = "Đã teleport đến vật phẩm gần nhất!", Duration=3})
    else
        game:GetService("StarterGui"):SetCore("SendNotification", {Text = "Không tìm thấy vật phẩm nào!", Duration=3})
    end
end

-- ===== AUTO FARM (kích hoạt mọi ClickDetector và ProximityPrompt) =====
local function AutoFarmLoop()
    if not Features.AutoFarm then return end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (root.Position - obj.Position).Magnitude < 20 then
            local cd = obj:FindFirstChildOfClass("ClickDetector")
            if cd then
                fireclickdetector(cd)
            end
            local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
            if prompt then
                prompt:Fire()
            end
        end
    end
end

-- ===== COMBAT =====
local function GetClosestEnemy()
    local closest, dist = nil, math.huge
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            if r then
                local d = (r.Position - root.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = p.Character
                end
            end
        end
    end
    return closest
end

local function KillAuraLoop()
    if not Features.KillAura then return end
    local enemy = GetClosestEnemy()
    if enemy and (enemy.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 15 then
        enemy.Humanoid:TakeDamage(9999)
        enemy:BreakJoints()
    end
end

local function AutoAttackLoop()
    if not Features.AutoAttack then return end
    local enemy = GetClosestEnemy()
    if enemy then
        local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then
            tool:Activate()
        end
    end
end

-- ===== MOVEMENT & SURVIVAL =====
local function SpeedHackLoop()
    if Features.SpeedHack and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = 50
    else
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = 16
        end
    end
end

local function InfiniteJumpLoop()
    if Features.InfiniteJump and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.JumpPower = 100
        LocalPlayer.Character.Humanoid.UseJumpPower = true
    end
end

local function NoclipLoop()
    if Features.Noclip and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Falling, false)
        LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
    end
end

local function AutoEatLoop()
    if not Features.AutoEat then return end
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health < 70 then
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") and (item.Name:lower():find("food") or item.Name:lower():find("heal")) then
                char.Humanoid:EquipTool(item)
                wait(0.5)
                char.Humanoid:UnequipTools()
                break
            end
        end
    end
end

-- Tìm RemoteEvent động cho Auto Cook, Auto Fuel, Auto Win
local function FindRemoteEventByPattern(pattern)
    for _, child in ipairs(ReplicatedStorage:GetChildren()) do
        if child:IsA("RemoteEvent") and child.Name:lower():find(pattern) then
            return child
        end
    end
    return nil
end

local function AutoCookLoop()
    if Features.AutoCook then
        local campfire = Workspace:FindFirstChild("Campfire")
        if campfire then
            local remote = FindRemoteEventByPattern("cook")
            if remote then
                remote:FireServer(campfire)
            end
        end
    end
end

local function AutoFuelLoop()
    if Features.AutoFuel then
        local campfire = Workspace:FindFirstChild("Campfire")
        if campfire then
            local fuel = campfire:FindFirstChild("Fuel")
            if fuel then fuel.Value = fuel.MaxValue or 100 end
        end
    end
end

local function AutoReloadLoop()
    if not Features.AutoReload then return end
    local char = LocalPlayer.Character
    if char then
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Ammo") then
                local ammo = tool.Ammo
                if ammo.Value < ammo.MaxValue then ammo.Value = ammo.MaxValue end
            end
        end
    end
end

local function AutoOpenChestLoop()
    if not Features.AutoOpenChest then return end
    local char = LocalPlayer.Character
    if not char then return end
    for _, chest in ipairs(Workspace:GetDescendants()) do
        if chest.Name:lower():find("chest") and (chest.Position - char.HumanoidRootPart.Position).Magnitude < 10 then
            local cd = chest:FindFirstChildOfClass("ClickDetector")
            if cd then fireclickdetector(cd) end
            local prompt = chest:FindFirstChildOfClass("ProximityPrompt")
            if prompt then prompt:Fire() end
        end
    end
end

-- ===== OTHER =====
local function BringItemsLoop()
    if not Features.BringItems then return end
    local char = LocalPlayer.Character
    if not char then return end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") or obj.Name:lower():find("resource") then
            local handle = obj:FindFirstChild("Handle") or obj
            if handle and handle:IsA("BasePart") and (handle.Position - char.HumanoidRootPart.Position).Magnitude < 50 then
                handle.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, -2, 3)
            end
        end
    end
end

local function MapRevealLoop()
    if Features.MapReveal then
        for _, child in ipairs(Workspace:GetChildren()) do
            if child:IsA("Folder") or child:IsA("Model") then
                child.Transparency = 0.5
            end
        end
    end
end

local function FullbrightLoop()
    if Features.Fullbright then
        Lighting.Brightness = 2
        Lighting:GetPropertyChangedSignal("Brightness"):Connect(function()
            Lighting.Brightness = 2
        end)
    end
end

local function InstantPromptLoop()
    if Features.InstantPrompt then
        for _, prompt in ipairs(Workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then
                prompt:Fire()
            end
        end
    end
end

local function SafeModeLoop()
    if Features.SafeMode then
        local name = LocalPlayer.Character:FindFirstChild("Name")
        if name then name:Destroy() end
    end
end

local function AutoWinLoop()
    if Features.AutoWin then
        local remote = FindRemoteEventByPattern("win") or FindRemoteEventByPattern("complete")
        if remote then remote:FireServer() end
    end
end

