-- ---- Combat ----
function GetClosestEnemy()
    local closest, dist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local d = (root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = p.Character
                end
            end
        end
    end
    return closest
end

local function AutoAttackLoop()
    if not Features.AutoAttack then return end
    local enemy = GetClosestEnemy()
    if enemy then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid:EquipTool(char:FindFirstChildOfClass("Tool") or nil)
            local tool = char:FindFirstChildOfClass("Tool")
            if tool then tool:Activate() end
        end
    end
end

local function KillAuraLoop()
    if not Features.KillAura then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            if root and (root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 15 then
                p.Character.Humanoid.Health = 0
            end
        end
    end
end

local function AutoHitLoop()
    if not Features.AutoHit then return end
    local enemy = GetClosestEnemy()
    if enemy and (enemy.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 10 then
        local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then tool:Activate() end
    end
end

local function ReachLoop()
    if Features.Reach and LocalPlayer.Character then
        for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do
            if tool:IsA("Tool") then
                tool:FindFirstChild("Handle"):Destroy()
            end
        end
    end
end

local function HitboxLoop()
    if Features.Hitbox and LocalPlayer.Character then
        for _, part in ipairs(LocalPlayer.Character:GetChildren()) do
            if part:IsA("BasePart") then
                part.Size = part.Size * 1.5
            end
        end
    end
end

-- ---- Movement ----
function FindClosestItemByName(name)
    local closest, dist = nil, math.huge
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name:lower():find(name) and obj:IsA("BasePart") then
            local d = (obj.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then
                dist = d
                closest = obj
            end
        end
    end
    return closest
end

local function TeleportToItemsLoop()
    if not Features.TeleportToItems then return end
    local target = FindClosestItemByName("item")
    if target then
        LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(target.Position + Vector3.new(0, 3, 0))
    end
end

local function TeleportToAreasLoop()
    if not Features.TeleportToAreas then return end
    for _, area in ipairs(Workspace:GetChildren()) do
        if area.Name:lower():find("area") or area.Name:lower():find("spawn") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(area.Position + Vector3.new(0, 3, 0))
            break
        end
    end
end

local function TeleportToBigTreesLoop()
    if not Features.TeleportToBigTrees then return end
    for _, tree in ipairs(Workspace:GetDescendants()) do
        if tree.Name:lower():find("tree") and tree:IsA("Model") and tree:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(tree.HumanoidRootPart.Position + Vector3.new(0, 3, 0))
            break
        end
    end
end

local function SpeedHackLoop()
    if Features.SpeedHack and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = 50
    else
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.WalkSpeed = 16
        end
    end
end

local function InfiniteJumpLoop()
    if Features.InfiniteJump and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.JumpPower = 100
        LocalPlayer.Character.Humanoid.UseJumpPower = true
    end
end

local function NoclipLoop()
    if Features.Noclip and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Falling, false)
        LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Freefall)
    end
end

-- ---- Survival ----
local function AutoEatLoop()
    if not Features.AutoEat then return end
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") and char.Humanoid.Health < 70 then
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") and (item.Name:lower():find("food") or item.Name:lower():find("eat")) then
                char.Humanoid:EquipTool(item)
                wait(0.5)
                char.Humanoid:UnequipTools()
                break
            end
        end
    end
end

local function AutoCookLoop()
    if not Features.AutoCook then return end
    local campfire = Workspace:FindFirstChild("Campfire")
    if campfire then
        local remote = ReplicatedStorage:FindFirstChild("CookRemote")
        if remote then remote:FireServer(campfire) end
    end
end

local function AutoFuelLoop()
    if not Features.AutoFuel then return end
    local campfire = Workspace:FindFirstChild("Campfire")
    if campfire then
        local fuel = campfire:FindFirstChild("Fuel")
        if fuel then fuel.Value = fuel.MaxValue or 100 end
    end
end

local function AutoReloadLoop()
    if not Features.AutoReload then return end
    local char = LocalPlayer.Character
    if char then
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool:FindFirstChild("Ammo") then
                local ammo = tool.Ammo
                if ammo.Value < ammo.MaxValue then ammo.Value = ammo.MaxValue end
            end
        end
    end
end

local function AutoOpenChestLoop()
    if not Features.AutoOpenChest then return end
    for _, chest in ipairs(Workspace:GetDescendants()) do
        if chest.Name:lower():find("chest") and chest:FindFirstChild("ClickDetector") then
            if (chest.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 10 then
                fireclickdetector(chest:FindFirstChildOfClass("ClickDetector"))
            end
        end
    end
end

-- ---- Others ----
local function BringItemsLoop()
    if not Features.BringItems then return end
    local char = LocalPlayer.Character
    if not char then return end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") or obj.Name:lower():find("resource") then
            local handle = obj:FindFirstChild("Handle") or obj
            if handle and handle:IsA("BasePart") and (handle.Position - char.HumanoidRootPart.Position).Magnitude < 50 then
                handle.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, -2, 3)
            end
        end
    end
end

local function MapRevealLoop()
    if Features.MapReveal then
        for _, child in ipairs(Workspace:GetChildren()) do
            if child:IsA("Folder") or child:IsA("Model") then
                child.Transparency = 0.5
            end
        end
    end
end

local function FullbrightLoop()
    if Features.Fullbright then
        Lighting.Brightness = 2
        Lighting:GetPropertyChangedSignal("Brightness"):Connect(function()
            Lighting.Brightness = 2
        end)
    end
end

local function InstantPromptLoop()
    if Features.InstantPrompt then
        for _, prompt in ipairs(Workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then
