-- ---- ESP ----
local espDrawings = {}
local function UpdateESP()
    if not Features.ESP then
        for _, v in pairs(espDrawings) do v:Remove() end
        espDrawings = {}
        return
    end
    for _, v in pairs(espDrawings) do v:Remove() end
    espDrawings = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local pos, onScreen = Camera:WorldToViewportPoint(obj.Position)
            if onScreen then
                local box = Drawing.new("Square")
                box.Thickness = 1
                box.Filled = false
                box.Position = Vector2.new(pos.X - 20, pos.Y - 20)
                box.Size = Vector2.new(40, 40)
                box.Visible = false
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= LocalPlayer.Character then
                    if Features.ESP_Players then
                        box.Color = Color3.fromRGB(255, 0, 0)
                        box.Visible = true
                    end
                elseif obj:IsA("Model") and obj.Name:lower():find("monster") or obj:FindFirstChild("Monster") then
                    if Features.ESP_Monsters then
                        box.Color = Color3.fromRGB(255, 100, 0)
                        box.Visible = true
                    end
                elseif obj:IsA("Tool") or obj:IsA("Part") and obj.Name:lower():find("item") then
                    if Features.ESP_Items then
                        box.Color = Color3.fromRGB(0, 255, 0)
                        box.Visible = true
                    end
                elseif obj.Name:lower():find("chest") then
                    if Features.ESP_Chests then
                        box.Color = Color3.fromRGB(255, 255, 0)
                        box.Visible = true
                    end
                elseif obj.Name:lower():find("tree") then
                    if Features.ESP_Trees then
                        box.Color = Color3.fromRGB(0, 255, 0)
                        box.Visible = true
                    end
                elseif obj.Name:lower():find("resource") or obj.Name:lower():find("wood") or obj.Name:lower():find("stone") then
                    if Features.ESP_Resources then
                        box.Color = Color3.fromRGB(0, 0, 255)
                        box.Visible = true
                    end
                end
                if box.Visible then
                    espDrawings[obj] = box
                end
            end
        end
    end
end

